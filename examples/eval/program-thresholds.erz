erz{v:1}
rule{id:"route_hot_incident",when:["event_type_present","event_type_equals:incident_candidate","payload_path_exists:dedupe.key","payload_path_gte:priority.score=0.9","payload_path_gt:metrics.retries=2","payload_path_lte:window.minutes_since_anchor=10","payload_path_lt:geo.distance_meters=500"],then:[{kind:"route",params:{target:"hot_lane",reason:"threshold_nested_match"}}]}
