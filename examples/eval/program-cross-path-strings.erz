erz{v:1}
rule{id:"route_cross_field_string_contract",when:["event_type_present","event_type_equals:normalize","payload_path_startswith_path:message.subject=policy.prefix","payload_path_contains_path:message.subject=policy.fragment","payload_path_endswith_path:message.subject=policy.suffix","payload_path_not_startswith_path:message.subject=blocked.prefix","payload_path_not_contains_path:message.subject=blocked.fragment","payload_path_not_endswith_path:message.subject=blocked.suffix","payload_path_startswith_path_ci:message.subject=policy.prefix_ci","payload_path_contains_path_ci:message.subject=policy.fragment_ci","payload_path_endswith_path_ci:message.subject=policy.suffix_ci","payload_path_not_startswith_path_ci:message.subject=blocked.prefix_ci","payload_path_not_contains_path_ci:message.subject=blocked.fragment_ci","payload_path_not_endswith_path_ci:message.subject=blocked.suffix_ci"],then:[{kind:"route",params:{target:"cross_path_string_lane",reason:"cross_field_string_payload_match"}}]}
