{
  "pack_id": "sprint-7-program-pack-4-refs-handoff",
  "title": "Refs-backed action-plan handoff fixture matrix",
  "rules": [
    {
      "id": "r_ops_primary_page",
      "when": [
        "event_type_present",
        "event_type_equals:alert",
        "payload_path_exists:alert.id",
        "payload_path_equals:routing.team=ops",
        "payload_path_gte:measurements.severity=0.9"
      ],
      "then": [
        {
          "kind": "notify",
          "params": {
            "channel_ref": "@ch_ops_pager",
            "labels": [
              {
                "value_ref": "@label_critical"
              },
              {
                "value_ref": "@label_ops"
              }
            ],
            "payload": {
              "owner": {
                "team_ref": "@team_ops"
              },
              "priority_ref": "@prio_p1",
              "runbook_ref": "@runbook_ops"
            },
            "template_ref": "@tpl_ops_page"
          }
        }
      ]
    },
    {
      "id": "r_security_triage",
      "when": [
        "event_type_present",
        "event_type_equals:alert",
        "payload_path_exists:alert.id",
        "payload_path_equals:routing.team=security",
        "payload_path_gte:measurements.severity=0.9"
      ],
      "then": [
        {
          "kind": "notify",
          "params": {
            "channel_ref": "@ch_sec_triage",
            "labels": [
              {
                "value_ref": "@label_critical"
              },
              {
                "value_ref": "@label_security"
              },
              {
                "value_ref": "@label_triage"
              }
            ],
            "payload": {
              "owner": {
                "team_ref": "@team_sec"
              },
              "priority_ref": "@prio_p1",
              "runbook_ref": "@runbook_sec"
            },
            "template_ref": "@tpl_sec_triage"
          }
        }
      ]
    },
    {
      "id": "r_ops_digest",
      "when": [
        "event_type_present",
        "event_type_equals:alert",
        "payload_path_equals:routing.team=ops",
        "payload_path_gte:measurements.severity=0.6",
        "payload_path_lt:measurements.severity=0.9"
      ],
      "then": [
        {
          "kind": "notify",
          "params": {
            "channel_ref": "@ch_ops_digest",
            "labels": [
              {
                "value_ref": "@label_warning"
              },
              {
                "value_ref": "@label_ops"
              }
            ],
            "payload": {
              "owner": {
                "team_ref": "@team_ops"
              },
              "priority_ref": "@prio_p2"
            },
            "template_ref": "@tpl_ops_digest"
          }
        }
      ]
    }
  ],
