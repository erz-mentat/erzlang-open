            "distance_meters": 320
          },
          "window": {
            "minutes_since_anchor": 6
          }
        }
      },
      "context": {
        "now": "2026-02-25T12:00:00Z",
        "seed": "case-attach-ops"
      },
      "expected_actions": [
        {
          "kind": "cluster_attach",
          "params": {
            "cluster_bucket": "ops",
            "mode": "dedup",
            "reason": "time_geo_category_match"
          }
        }
      ],
      "expected_trace": [
        {
          "rule_id": "r_cluster_attach_ops",
          "matched_clauses": [
            "event_type_present",
            "event_type_equals:incident_candidate",
            "payload_path_exists:dedupe.key",
            "payload_path_equals:category=ops",
            "payload_path_lte:window.minutes_since_anchor=10",
            "payload_path_lte:geo.distance_meters=500"
          ],
          "score": 1.0,
