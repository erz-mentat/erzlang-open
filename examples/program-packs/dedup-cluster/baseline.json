{
  "pack_id": "sprint-7-program-pack-2-dedup-cluster",
  "title": "Dedup/cluster policy on canonical runtime payload paths",
  "fixture_shape": "canonical_runtime_event",
  "runtime_contract": {
    "time_window_minutes": 10,
    "geo_radius_meters": 500,
    "category_path": "category",
    "dedupe_key_path": "dedupe.key",
    "time_minutes_path": "window.minutes_since_anchor",
    "geo_distance_path": "geo.distance_meters"
  },
  "rules": [
    {
      "id": "r_cluster_attach_ops",
      "when": [
        "event_type_present",
        "event_type_equals:incident_candidate",
        "payload_path_exists:dedupe.key",
        "payload_path_equals:category=ops",
        "payload_path_lte:window.minutes_since_anchor=10",
        "payload_path_lte:geo.distance_meters=500"
      ],
      "then": [
        {
          "kind": "cluster_attach",
          "params": {
            "cluster_bucket": "ops",
            "mode": "dedup",
            "reason": "time_geo_category_match"
          }
        }
      ]
    },
    {
      "id": "r_cluster_attach_security",
      "when": [
        "event_type_present",
        "event_type_equals:incident_candidate",
        "payload_path_exists:dedupe.key",
        "payload_path_equals:category=security",
        "payload_path_lte:window.minutes_since_anchor=10",
        "payload_path_lte:geo.distance_meters=500"
      ],
      "then": [
        {
          "kind": "cluster_attach",
          "params": {
            "cluster_bucket": "security",
            "mode": "dedup",
            "reason": "time_geo_category_match"
          }
        }
      ]
    },
    {
      "id": "r_cluster_new_ops_time",
      "when": [
        "event_type_present",
        "event_type_equals:incident_candidate",
        "payload_path_exists:dedupe.key",
        "payload_path_equals:category=ops",
        "payload_path_gt:window.minutes_since_anchor=10"
      ],
      "then": [
        {
          "kind": "cluster_new",
          "params": {
            "cluster_bucket": "ops",
            "mode": "new",
            "reason": "time_window_miss"
          }
        }
      ]
    },
    {
      "id": "r_cluster_new_security_geo",
      "when": [
        "event_type_present",
        "event_type_equals:incident_candidate",
        "payload_path_exists:dedupe.key",
        "payload_path_equals:category=security",
        "payload_path_gt:geo.distance_meters=500"
      ],
      "then": [
        {
          "kind": "cluster_new",
          "params": {
            "cluster_bucket": "security",
            "mode": "new",
            "reason": "geo_radius_miss"
          }
        }
      ]
    }
  ],
  "fixtures": [
