erz{v:1}
rule{id:"route_object_key_sets",when:["event_type_present","event_type_equals:normalize","payload_path_has_keys:enrichment.labels=severity,team","payload_path_missing_keys:enrichment.labels=legacy,deprecated","payload_path_has_keys_ci:headers=x-env,x-trace-id,x-alt-route","payload_path_missing_keys_ci:headers=x-blocked,x-legacy"],then:[{kind:"route",params:{reason:"object_key_set_match",target:"object_key_set_lane"}}]}
