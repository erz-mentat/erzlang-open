{
  "pack_id": "sprint-7-pack-03-alert-routing",
  "title": "Alert routing by numeric severity/confidence thresholds",
  "calibration_note": "Runtime clauses stay structural. Packs now route directly on nested numeric measurements via deterministic threshold predicates, no upstream bucket projection required. Calibration only enriches trace probabilities.",
  "rules": [
    {
      "id": "r01_page_primary",
      "when": [
        "event_type_present",
        "event_type_equals:alert",
        "payload_path_exists:alert.id",
        "payload_path_gte:measurements.severity=0.9",
        "payload_path_gte:measurements.confidence=0.85"
      ],
      "then": [
        {
          "kind": "route",
          "params": {
            "priority": "p1",
            "reason": "critical+high_confidence",
            "target": "oncall_primary",
            "via": "pager"
          }
        }
      ]
    },
    {
      "id": "r02_manual_review",
      "when": [
        "event_type_present",
        "event_type_equals:alert",
        "payload_path_exists:alert.id",
        "payload_path_gte:measurements.severity=0.9",
        "payload_path_lt:measurements.confidence=0.85"
      ],
      "then": [
        {
          "kind": "route",
          "params": {
            "priority": "p1",
            "reason": "critical+low_confidence",
            "target": "safety_triage",
            "via": "human_review"
          }
        }
      ]
    },
    {
      "id": "r03_ops_digest",
      "when": [
        "event_type_present",
        "event_type_equals:alert",
        "payload_path_exists:alert.id",
        "payload_path_gte:measurements.severity=0.6",
        "payload_path_lt:measurements.severity=0.9",
        "payload_path_gte:measurements.confidence=0.85"
      ],
      "then": [
        {
          "kind": "route",
          "params": {
            "priority": "p2",
            "reason": "warning+high_confidence",
            "target": "ops_digest",
            "via": "queue"
          }
        }
      ]
    }
  ],
